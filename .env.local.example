# ==== 开发模式开关 ====
# 设为 true 使用本地 Mock 登录（无需 GitHub OAuth App）
# 设为 false 使用真实 GitHub OAuth 登录
NEXTAUTH_MOCK=true

# ==== GitHub OAuth App（NEXTAUTH_MOCK=false 时必填）====
# 注册教程：https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ==== Supabase（NEXTAUTH_MOCK=false 时必填）====
# 获取地址：https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==== NextAuth.js（必填）====
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ==== API Key Encryption（必填）====
# 用于加密用户存储的 Anthropic API Key
# 生成命令：openssl rand -base64 32
API_KEY_ENCRYPTION_KEY=your_encryption_key_here

# ==== 前端公开变量 ====
NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
NEXT_PUBLIC_MOCK_LOGIN=$NEXTAUTH_MOCK
