# ==== 开发模式开关 ====
# 设为 true 使用本地 Mock 登录（无需 GitHub OAuth App）
# 设为 false 使用真实 GitHub OAuth 登录
NEXTAUTH_MOCK=true

# ==== GitHub OAuth App（NEXTAUTH_MOCK=false 时必填）====
# 注册教程：https://github.com/settings/applications/new
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ==== Supabase（NEXTAUTH_MOCK=false 时必填）====
# 获取地址：https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==== NextAuth.js（必填）====
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# ==== API Key Encryption（必填）====
# 用于加密用户存储的 Anthropic API Key
# 生成命令：openssl rand -base64 32
API_KEY_ENCRYPTION_KEY=your_encryption_key_here

# ==== Agent Runtime JWT（M5+ 必填）====
# BFF 签发给 Codespace agent-runtime 的短期 JWT 用的 HS256 密钥
# Codespace 侧需要把相同值作为 GitHub Codespaces user secret 配置
# 生成命令：openssl rand -base64 32
AGENT_RUNTIME_JWT_SECRET=your_agent_runtime_jwt_secret

# ==== Agent Runtime 开发模式直连（可选）====
# 本地 dev 时绕过 Codespace 路由，直接连到本机跑的 agent-runtime
# 例如：先在 apps/agent-runtime 里 `npm run dev`，再把这里填成 ws://127.0.0.1:3030/agent
# 生产环境留空
AGENT_RUNTIME_DEV_URL=

# ==== 前端公开变量 ====
NEXT_PUBLIC_SUPABASE_URL=$SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
NEXT_PUBLIC_MOCK_LOGIN=$NEXTAUTH_MOCK
